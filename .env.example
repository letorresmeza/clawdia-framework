# ─────────────────────────────────────────
# Clawdia Framework — Environment Config
# ─────────────────────────────────────────

# Message Bus
CLAWBUS_URL=nats://localhost:4222

# Database
DATABASE_URL=postgres://clawdia:clawdia-dev@localhost:5432/clawdia

# Dashboard
DASHBOARD_PORT=3000

# Agent Runtime
DEFAULT_RUNTIME=docker
DEFAULT_AGENT_IMAGE=node:20-slim

# Notifications
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Blockchain (for Economy layer)
EVM_RPC_URL=https://sepolia.base.org
ESCROW_CONTRACT_ADDRESS=
OPERATOR_PRIVATE_KEY=

# Billing
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=

# External APIs (for trading bot example)
POLYMARKET_API_KEY=
RSS_FEEDS_URL=
TWITTER_BEARER_TOKEN=
